flowchart TB
    %% =========================
    %% LLM Client Architecture
    %% =========================

    subgraph S1[Caller Layer]
        A1[Business Code]
        A2[quick_chat prompt]
        A3[chat_with_retry messages]
    end

    subgraph S2[Configuration Layer]
        B1[get_env_provider]
        B2[LLM_PROVIDER]
        B3[API Keys / Base URLs / Model Names]
    end

    subgraph S3[Provider Layer]
        C1[LLMProvider<br>Abstract Base Class]
        C2[ClaudeCompatibleProvider]
    end

    subgraph S4[Request Execution Layer]
        D1[Build Claude-compatible payload]
        D2[httpx.Client.post chat/completions]
        D3[Claude-compatible endpoint]
    end

    subgraph S5[Normalization & Resilience Layer]
        E1[_extract_content]
        E2[_extract_usage]
        E3[estimate_token_usage]
        E4[calculate_cost_usd]
        E5[LLMResponse]
        E6[Retry with exponential backoff]
        E7[ProviderConfigError]
    end

    A1 --> A2
    A1 --> A3
    A2 --> A3

    A3 --> B1
    B1 --> B2
    B1 --> B3

    B1 --> C2
    C1 --> C2

    C2 --> D1
    D1 --> D2
    D2 --> D3

    D3 --> E1
    D3 --> E2

    E2 -->|usage present| E4
    E2 -->|usage missing| E3
    E1 --> E4
    E3 --> E4

    E1 --> E5
    E2 --> E5
    E4 --> E5

    A3 --> E6
    E6 --> A3

    B1 -->|unsupported provider| E7
